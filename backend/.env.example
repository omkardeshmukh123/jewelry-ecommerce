# ============================================================
# Jewellery E-Commerce Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# ============================================================

# Server Configuration
PORT=5000
NODE_ENV=production          # development | production

# Database Configuration
# Get from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/jewelry-ecommerce?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRE=30d

# Admin Credentials (only used by: npm run seed)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_before_seeding
ADMIN_NAME=Admin User

# WhatsApp Configuration
WHATSAPP_NUMBER=91XXXXXXXXXX   # country code + number, no +

# CORS — comma-separated list of allowed frontend origins (production)
# Example: https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.vercel.app

# Google OAuth Configuration
# From: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# AWS S3 Configuration (for product images)
# Region: ap-south-1 (Mumbai) recommended for India, us-east-1 for global
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your-bucket-name
